#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ulf/daten/Web-Development-with-MongoDB-and-Node.js/node_modules/.pnpm/sshpk@1.18.0/node_modules/sshpk/bin/node_modules:/home/ulf/daten/Web-Development-with-MongoDB-and-Node.js/node_modules/.pnpm/sshpk@1.18.0/node_modules/sshpk/node_modules:/home/ulf/daten/Web-Development-with-MongoDB-and-Node.js/node_modules/.pnpm/sshpk@1.18.0/node_modules:/home/ulf/daten/Web-Development-with-MongoDB-and-Node.js/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ulf/daten/Web-Development-with-MongoDB-and-Node.js/node_modules/.pnpm/sshpk@1.18.0/node_modules/sshpk/bin/node_modules:/home/ulf/daten/Web-Development-with-MongoDB-and-Node.js/node_modules/.pnpm/sshpk@1.18.0/node_modules/sshpk/node_modules:/home/ulf/daten/Web-Development-with-MongoDB-and-Node.js/node_modules/.pnpm/sshpk@1.18.0/node_modules:/home/ulf/daten/Web-Development-with-MongoDB-and-Node.js/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../bin/sshpk-verify" "$@"
else
  exec node  "$basedir/../../bin/sshpk-verify" "$@"
fi
